        100% {background-position: 0% 50%;}
    }

    h1 {
        text-align:center;
        color:white;
        text-shadow:0 0 25px white;
    }

    .note-box {
        background: rgba(0,255,255,0.15);
        border: 2px solid cyan;
        border-radius: 20px;
        padding: 20px;
        margin: 12px 0;
        text-align:center;
        font-size:28px;
        color:white;
        box-shadow:0 0 15px cyan;

        animation: pulse 1s infinite alternate;
    }

    @keyframes pulse {
        from {
            transform: scale(1);
            box-shadow:0 0 10px cyan;
