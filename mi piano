import streamlit as st
import random

# =====================================
# CONFIGURACIÓN
# =====================================
st.set_page_config(
    page_title="Emoji Music Ultra Pro",
    page_icon="🎧",
    layout="centered"
)

# =====================================
# ESTILOS CYBERPUNK
# =====================================
st.markdown("""
<style>
    .stApp {
        background: linear-gradient(-45deg,
        #ff0000,
        #ff7f00,
        #ffff00,
        #00ff00,
        #00ffff,
        #0000ff,
